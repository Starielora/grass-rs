#version 450 core
#extension GL_EXT_mesh_shader : require

#include "descriptor_set.glsl"
#include "meshlet_common.glsl"

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 124) out;

layout(location = 0) out vec4 color[];

uint hash(uint a)
{
  a = (a + 0x7ed55d16) + (a << 12);
  a = (a ^ 0xc761c23c) ^ (a >> 19);
  a = (a + 0x165667b1) + (a << 5);
  a = (a + 0xd3a2646c) ^ (a << 9);
  a = (a + 0xfd7046c5) + (a << 3);
  a = (a ^ 0xb55a4f09) ^ (a >> 16);
  return a;
}

taskPayloadSharedEXT MeshletSharedData sharedData;

void main()
{
  // uint mi = gl_WorkGroupID.x;
  uint mi = gl_WorkGroupID.x + sharedData.meshletOffset;
  uint ti = gl_LocalInvocationID.x;

  uint vertex_count = push_constants.meshlet_data.meshlets[mi].vertex_count;
  uint triangle_count = push_constants.meshlet_data.meshlets[mi].triangle_count;
  uint vertex_offset = push_constants.meshlet_data.meshlets[mi].vertex_offset;
  uint triangle_offset = push_constants.meshlet_data.meshlets[mi].triangle_offset;

  SetMeshOutputsEXT(vertex_count, triangle_count);

  for (uint i = ti; i < triangle_count; i += 64) {
    uint ia = uint(push_constants.meshlet_triangles.meshlet_triangles[triangle_offset + i * 3 + 0]);
    uint ib = uint(push_constants.meshlet_triangles.meshlet_triangles[triangle_offset + i * 3 + 1]);
    uint ic = uint(push_constants.meshlet_triangles.meshlet_triangles[triangle_offset + i * 3 + 2]);

    gl_PrimitiveTriangleIndicesEXT[i] = uvec3(ia, ib, ic);
  }

  for (uint i = ti; i < vertex_count; i += 64) {
    uint vi = push_constants.meshlet_vertices.meshlet_vertices[vertex_offset + i];
    Vertex v = push_constants.mesh_vertex_data.vertices[vi];
    vec4 position = push_constants.camera_data.projview * push_constants.mesh_data.model_matrix * vec4(v.vx, v.vy, v.vz, 1.0);
    vec3 normal = vec3(v.nx, v.ny, v.nz);

    gl_MeshVerticesEXT[i].gl_Position = position;

    uint mhash = hash(mi);
    vec3 mcolor = vec3(float(mhash & 255), float((mhash >> 8) & 255), float((mhash >> 16) & 255)) / 255.0;
    color[i] = vec4(mcolor, 1.0);
  }
}
